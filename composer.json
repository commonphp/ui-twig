{
  "name": "comphp/ui-twig",
  "type": "library",
  "description": "UI Driver for CommonPHP that wraps the Twig library for output rendering",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\Drivers\\UI\\Twig\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\Drivers\\UI\\Twig\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "comphp/database": "^0.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}